# ══════════════════════════════════════════════════════
# AlzMedia — Environment Variables
# Hosted on Render (single service — frontend + backend)
# ══════════════════════════════════════════════════════

# ── REQUIRED — server won't start without these ───────
PORT=3000
NODE_ENV=production

# Both are the same URL since frontend + backend are
# on one Render service
SERVER_URL=https://alzmedia.onrender.com
CLIENT_URL=https://alzmedia.onrender.com

DATABASE_URL=postgresql://user:password@host:5432/alzmedia

JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string

# ── OPTIONAL — payment features disabled if missing ───
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL — media upload disabled if missing ───────
# Get API_ID and API_HASH from my.telegram.org
# SESSION = reuse your existing AlzCloud session string
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_SESSION=your_session_string_from_alzcloud
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# ── OPTIONAL ──────────────────────────────────────────
IP_HASH_SECRET=random_secret_for_ip_hashing
